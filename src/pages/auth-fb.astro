---
import Layout from '~/layouts/PageLayout.astro';
import FacebookSDK from '~/components/common/FacebookSDK.astro';
import FacebookSignupButton from '~/components/widgets/FacebookSignupButton';
import HeroText from '~/components/widgets/HeroText.astro';

const configId = import.meta.env.PUBLIC_FACEBOOK_CONFIG_ID;

const metadata = {
  title: 'Conectar Cuenta de Facebook - SG Cloud',
  description: 'Conecta tu cuenta de Facebook Business con los servicios de SG Cloud',
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <!-- Load Facebook SDK (only on this page) -->
  <FacebookSDK />

  <HeroText tagline="Integración" title="Conecta tu Cuenta de Facebook Business" />

  <section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-20 mx-auto max-w-3xl">
    <div class="bg-white dark:bg-slate-900 rounded-xl shadow-lg p-8">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Autoriza la Conexión de WhatsApp Business</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
          Conecta tu cuenta de Facebook Business para habilitar funciones avanzadas de WhatsApp Business y chatbots de
          Messenger con SG Cloud.
        </p>

        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4 mb-8">
          <h3 class="text-sm font-semibold text-blue-900 dark:text-blue-100 mb-2">Permisos Solicitados:</h3>
          <ul class="text-sm text-blue-800 dark:text-blue-200 text-left space-y-1 max-w-md mx-auto">
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span><strong>Gestión Empresarial:</strong> Administrar configuraciones de negocio</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span><strong>WhatsApp Business:</strong> Gestionar y enviar mensajes de WhatsApp</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span><strong>Messenger:</strong> Gestionar mensajes y conversaciones de Messenger</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span><strong>Páginas de Facebook:</strong> Acceso a metadatos y engagement de páginas</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Preact Component with client:load -->
      <div class="flex justify-center">
        <FacebookSignupButton client:load configId={configId} />
      </div>

      <div class="mt-8 text-center text-sm text-gray-500 dark:text-gray-400">
        <p>
          Al conectar, aceptas nuestros <a href="/terms" class="text-blue-600 hover:underline">Términos de Servicio</a>
          y <a href="/privacy" class="text-blue-600 hover:underline">Política de Privacidad</a>
        </p>
        <p class="mt-2">¿Necesitas ayuda? <a href="/contact" class="text-blue-600 hover:underline">Contáctanos</a></p>
      </div>
    </div>
  </section>
</Layout>
