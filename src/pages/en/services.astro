---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';

import { useTranslations } from '~/i18n/translations';

const t = useTranslations('en');

const metadata = {
  title: 'Services - SG Cloud',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline={t.services.tagline}
    title={t.services.title}
    subtitle={t.services.subtitle}
    actions={[
      {
        variant: 'primary',
        text: t.hero.ctaPrimary,
        href: `https://wa.me/56939242145?text=${encodeURIComponent(t.whatsapp.messageServices)}`,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />

  <!-- Main Services - Features Widget *************** -->

  <Features
    id="main-services"
    items={[
      {
        title: t.services.website.title,
        description: t.services.website.description,
        icon: 'tabler:world',
      },
      {
        title: t.services.apps.title,
        description: t.services.apps.description,
        icon: 'tabler:device-mobile',
      },
      {
        title: t.services.scrapers.title,
        description: t.services.scrapers.description,
        icon: 'tabler:robot',
      },
      {
        title: t.services.ai.title,
        description: t.services.ai.description,
        icon: 'tabler:brain',
      },
      {
        title: t.services.chatbots.title,
        description: t.services.chatbots.description,
        icon: 'tabler:message-chatbot',
      },
      {
        title: t.services.fullstack.title,
        description: t.services.fullstack.description,
        icon: 'tabler:stack-2',
      },
    ]}
  />

  <!-- Content - Websites Details ******************* -->

  <Content
    isReversed
    title="Modern, Fast, & SEO-Optimized Websites"
    items={[
      {
        title: 'Built with Latest Technologies',
        description:
          'We use modern frameworks like Astro, Next.js, and React to build lightning-fast websites that provide exceptional user experiences.',
      },
      {
        title: 'SEO & Performance Optimized',
        description:
          'Every site we build is optimized for search engines and performance. Fast load times, clean code, and semantic HTML ensure your site ranks well.',
      },
      {
        title: 'Responsive & Accessible',
        description:
          'Your website will look great and work perfectly on all devices - from mobile phones to large desktop screens. Fully accessible and compliant with WCAG standards.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1593720213428-28a5b9e94613?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80',
      alt: 'Modern website development',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Website Development</h3>
      From simple landing pages to complex web applications, we build solutions that drive results.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content - AI & Automation Details ******************* -->

  <Content
    title="AI Models & Intelligent Automation"
    items={[
      {
        title: 'Custom Machine Learning Solutions',
        description:
          'We develop custom AI models tailored to your specific business needs - from predictive analytics to recommendation systems.',
      },
      {
        title: 'AI-Powered Chatbots',
        description:
          'Intelligent chatbots that understand natural language, provide 24/7 customer support, and can be trained on your specific knowledge base.',
      },
      {
        title: 'Process Automation',
        description:
          'Automate repetitive tasks with web scrapers, bots, and custom automation scripts. Save time and reduce manual errors.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80',
      alt: 'AI and automation',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Artificial Intelligence & Automation
      </h3>
      Leverage the power of AI to transform your business operations and customer experiences.
    </Fragment>
  </Content>

  <!-- Content - Mobile & PWA Details ******************* -->

  <Content
    isReversed
    title="Progressive Web Apps (PWAs) & Mobile Solutions"
    items={[
      {
        title: 'Cross-Platform Compatibility',
        description:
          'Build once, run anywhere. PWAs work seamlessly across all devices and platforms without the need for separate codebases.',
      },
      {
        title: 'Offline Functionality',
        description:
          'PWAs can work offline or on low-quality networks, ensuring your app is always accessible to users.',
      },
      {
        title: 'No App Store Required',
        description:
          'Bypass app store approval processes and fees. Users can install PWAs directly from your website, and you maintain full control over updates.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80',
      alt: 'Mobile and PWA development',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Mobile Applications</h3>
      Native-like experiences without the complexity and cost of traditional mobile app development.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Technologies We Use - Features2 Widget ************** -->

  <Features2
    title="Technologies We Use"
    subtitle="We stay up-to-date with the latest tools and frameworks to deliver cutting-edge solutions"
    columns={3}
    items={[
      {
        title: 'Frontend',
        description: 'Astro, React, Preact, Vue, Next.js, Tailwind CSS',
        icon: 'tabler:code',
      },
      {
        title: 'Backend',
        description: 'Node.js, Python, Firebase, PostgreSQL, MongoDB',
        icon: 'tabler:server',
      },
      {
        title: 'AI/ML',
        description: 'TensorFlow, PyTorch, OpenAI, LangChain, Hugging Face',
        icon: 'tabler:brain',
      },
      {
        title: 'Mobile',
        description: 'PWA, React Native, Ionic, Capacitor',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'DevOps',
        description: 'Docker, Firebase, Vercel, GitHub Actions, CI/CD',
        icon: 'tabler:cloud',
      },
      {
        title: 'Tools',
        description: 'Git, VS Code, Figma, Postman, Chrome DevTools',
        icon: 'tabler:tool',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: t.cta.primaryButton,
        href: `https://wa.me/56939242145?text=${encodeURIComponent(t.whatsapp.messageServices)}`,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        variant: 'secondary',
        text: 'About Us',
        href: '/en/about',
      },
    ]}
  >
    <Fragment slot="title">
      {t.cta.title}<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> {t.cta.titleBreak}</span>
    </Fragment>

    <Fragment slot="subtitle">
      {t.cta.subtitle}
    </Fragment>
  </CallToAction>
</Layout>
