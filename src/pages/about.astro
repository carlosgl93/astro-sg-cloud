---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { useTranslations } from '~/i18n/translations';

const t = useTranslations('es');

const metadata = {
  title: 'Nosotros - SG Cloud',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline={t.about.tagline}
    image={{
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team collaboration',
    }}
  >
    <Fragment slot="title">
      {t.about.heroTitle} <br />
      <span class="text-accent dark:text-white"> {t.about.heroTitleHighlight}</span>
    </Fragment>

    <Fragment slot="subtitle">
      {t.about.heroSubtitle}
    </Fragment>
  </Hero>

  <!-- Content Widget - Our Story **************** -->

  <Content
    isReversed
    tagline={t.about.storyTagline}
    title={t.about.storyTitle}
    items={[
      {
        title: t.about.storyItem1Title,
        description: t.about.storyItem1Description,
      },
      {
        title: t.about.storyItem2Title,
        description: t.about.storyItem2Description,
      },
      {
        title: t.about.storyItem3Title,
        description: t.about.storyItem3Description,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531973576160-7125cd663d86?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Developers working',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{t.about.storyContentTitle}</h3>
      {t.about.storyContentSubtitle}
    </Fragment>
  </Content>

  <!-- Team Section - Features2 Widget ************** -->

  <Features2
    title={t.about.teamTitle}
    tagline={t.about.teamTagline}
    items={[
      {
        title: t.about.carlosTitle,
        description: t.about.carlosDescription,
        icon: 'tabler:user',
      },
      {
        title: t.about.benjaminTitle,
        description: t.about.benjaminDescription,
        icon: 'tabler:user',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Stats Widget ****************** -->

  <Stats
    title={t.about.impactTitle}
    stats={[
      { title: t.about.impactYears, amount: '15+' },
      { title: t.about.impactProjects, amount: '50+' },
      { title: t.about.impactTech, amount: '20+' },
      { title: t.about.impactSatisfaction, amount: '100%' },
    ]}
  />

  <!-- What We Believe - Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: t.about.value1Title,
        description: t.about.value1Description,
      },
      {
        title: t.about.value2Title,
        description: t.about.value2Description,
      },
      {
        title: t.about.value3Title,
        description: t.about.value3Description,
      },
      {
        title: t.about.value4Title,
        description: t.about.value4Description,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team values',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{t.about.valuesTitle}</h3>
      {t.about.valuesSubtitle}
    </Fragment>
  </Content>

  <!-- Technologies - Features2 Widget ************** -->

  <Features2
    title={t.about.techTitle}
    subtitle={t.about.techSubtitle}
    tagline={t.about.techTagline}
    columns={3}
    items={[
      {
        title: t.about.techFrontend,
        description: t.about.techFrontendList,
        icon: 'tabler:layout-2',
      },
      {
        title: t.about.techBackend,
        description: t.about.techBackendList,
        icon: 'tabler:database',
      },
      {
        title: t.about.techAI,
        description: t.about.techAIList,
        icon: 'tabler:brain',
      },
      {
        title: t.about.techMobile,
        description: t.about.techMobileList,
        icon: 'tabler:device-mobile',
      },
      {
        title: t.about.techDevOps,
        description: t.about.techDevOpsList,
        icon: 'tabler:cloud',
      },
      {
        title: t.about.techTools,
        description: t.about.techToolsList,
        icon: 'tabler:tools',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: t.about.ctaButton,
        href: `https://wa.me/56939242145?text=${encodeURIComponent(t.whatsapp.messageAbout)}`,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        variant: 'secondary',
        text: t.about.ctaServicesButton,
        href: '/services',
      },
    ]}
  >
    <Fragment slot="title"> {t.about.ctaTitle} </Fragment>

    <Fragment slot="subtitle"> {t.about.ctaSubtitle} </Fragment>
  </CallToAction>
</Layout>
