---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features from '~/components/widgets/Features.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import { useTranslations } from '~/i18n/translations';

const t = useTranslations('es');

const metadata = {
  title: 'Servicios - SG Cloud',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline={t.services.tagline}
    title={t.services.title}
    subtitle={t.services.subtitle}
    actions={[
      {
        variant: 'primary',
        text: t.contact.ctaButton,
        href: `https://wa.me/56939242145?text=${encodeURIComponent(t.whatsapp.messageServices)}`,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />

  <!-- Services Features Widget *************** -->

  <Features
    id="services-detail"
    items={[
      {
        title: t.services.website.title,
        description: t.services.website.description,
        icon: 'tabler:world',
      },
      {
        title: t.services.apps.title,
        description: t.services.apps.description,
        icon: 'tabler:device-mobile',
      },
      {
        title: t.services.scrapers.title,
        description: t.services.scrapers.description,
        icon: 'tabler:robot',
      },
      {
        title: t.services.ai.title,
        description: t.services.ai.description,
        icon: 'tabler:brain',
      },
      {
        title: t.services.chatbots.title,
        description: t.services.chatbots.description,
        icon: 'tabler:message-chatbot',
      },
      {
        title: t.services.fullstack.title,
        description: t.services.fullstack.description,
        icon: 'tabler:stack-2',
      },
    ]}
  />

  <!-- CTA Widget ******************* -->

  <CallToAction
    title={t.cta.title}
    subtitle={t.cta.subtitle}
    actions={[
      {
        variant: 'primary',
        text: t.cta.primaryButton,
        href: `https://wa.me/56939242145?text=${encodeURIComponent(t.whatsapp.messageServices)}`,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        variant: 'secondary',
        text: t.nav.about,
        href: '/about',
      },
    ]}
  />
</Layout>
