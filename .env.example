# Firebase Configuration
# Get these values from your Firebase project settings:
# https://console.firebase.google.com/project/YOUR_PROJECT_ID/settings/general

# Required for Firebase initialization
PUBLIC_FIREBASE_API_KEY=your-api-key-here
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional - For Firebase Analytics
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Note: These environment variables are PUBLIC (exposed to the browser)
# because Firebase SDK requires them on the client side.
# Firebase security is handled through Firestore Security Rules and Storage Rules,
# not by hiding these configuration values.

# Facebook OAuth Configuration
# Get these values from your Facebook App settings:
# https://developers.facebook.com/apps/YOUR_APP_ID/settings/basic/
PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id-here

# Facebook Embedded Signup Configuration ID
# Get this from your Embedded Signup configuration:
# https://developers.facebook.com/apps/YOUR_APP_ID/whatsapp-business/wa-embedded-signup/
PUBLIC_FACEBOOK_CONFIG_ID=your-configuration-id-here
